# Copy this file to .env and fill in your credentials

# Supabase — Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Flutterwave — Dashboard → Settings → API Keys (public key only in frontend)
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxx

# Edge function secrets (set in Supabase Dashboard → Edge Functions → Secrets, NOT in .env):
# FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxx
# FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxx
# PAYMENT_DEV_MODE=true   # ONLY for testing without Flutterwave — auto-approves payments; never set in production
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Paddimi <notifications@yourdomain.com>
# TERMII_API_KEY=xxxxxxxx
# TERMII_SENDER_ID=Paddimi
