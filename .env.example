# Copy this file to .env and fill in your credentials

# Supabase — Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Paystack — Dashboard → Settings → API Keys (public key only in frontend)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx

# Edge function secrets (set in Supabase Dashboard → Edge Functions → Secrets, NOT in .env):
# PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
# PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx
# PAYMENT_DEV_MODE=true   # ONLY for testing without Paystack — auto-approves payments; never set in production
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Paddimi <notifications@yourdomain.com>
# TERMII_API_KEY=xxxxxxxx
# TERMII_SENDER_ID=Paddimi
